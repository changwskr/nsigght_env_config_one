<?xml version="1.0" encoding="UTF-8"?>
<!-- NSIGHT Tomcat server.xml — 개발용 단일 VM (32 vCPU / 256GB)
     Apache + Tomcat 동일 서버, DeltaManager Cluster 미사용 -->
<Server port="${shutdown.port}" shutdown="SHUTDOWN">
  <Listener className="org.apache.catalina.startup.VersionLoggerListener" />
  <Listener className="org.apache.catalina.core.JreMemoryLeakPreventionListener" />
  <Service name="Catalina">
    <Connector port="${http.port}" protocol="org.apache.coyote.http11.Http11NioProtocol"
      maxThreads="1600" minSpareThreads="200" acceptCount="1000"
      maxConnections="20000" connectionTimeout="8000"
      keepAliveTimeout="5000" maxKeepAliveRequests="100"
      URIEncoding="UTF-8" enableLookups="false"
      proxyName="nh.marketing.com" proxyPort="443" scheme="https" secure="true" />
    <!-- 단일 노드 개발 — jvmRoute·Cluster 없음 -->
    <Engine name="Catalina" defaultHost="localhost">
      <Host name="localhost" appBase="webapps" unpackWARs="true" autoDeploy="true">
        <Valve className="org.apache.catalina.valves.AccessLogValve"
          directory="logs" prefix="nsight_access" suffix=".log"
          pattern="%h %l %u %t &quot;%r&quot; %s %b %D %{JSESSIONID}c %{X-GUID}i" />
      </Host>
    </Engine>
  </Service>
</Server>
